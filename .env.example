# Copy this file to .env and adjust values before running Docker Compose.
# All values below are the defaults used when the variable is not set.

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=semesterapp
MYSQL_USER=semesterapp
MYSQL_PASSWORD=semesterpassword

# ── Backend ───────────────────────────────────────────────────────────────────
# CORS_ORIGIN restricts which origins may call the API.
# Use * for fully open local network access.
CORS_ORIGIN=*
